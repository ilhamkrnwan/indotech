# ─────────────────────────────────────────────────────────────
# Strategi: abaikan SEMUA isi WordPress, lalu izinkan HANYA
# file custom milik proyek Indotech:
#   - wp-content/themes/indotech_custom/   (tema utama)
#   - wp-content/plugins/indotech-core/    (plugin inti)
#   - speedrun/                            (docs & planning)
# ─────────────────────────────────────────────────────────────

# 1. Abaikan semua file di root
/*

# 2. Whitelist file penting di root
!.gitignore
!README.md
!update.md
!Update.md

# ── Tema Custom: indotech_custom ──────────────────────────────
# Buka jalur level per level (wajib di setiap level folder)
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/indotech_custom/

# Exclude hal yang tidak perlu di-commit
wp-content/themes/indotech_custom/**/node_modules/
wp-content/themes/indotech_custom/**/vendor/
wp-content/themes/indotech_custom/**/*.log
wp-content/themes/indotech_custom/**/.DS_Store

# ── Plugin Custom: indotech-core ─────────────────────────────
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/indotech-core/

# Exclude vendor (composer) karena bisa di-generate ulang
wp-content/plugins/indotech-core/vendor/
wp-content/plugins/indotech-core/**/*.log
wp-content/plugins/indotech-core/**/.DS_Store

# ── Speedrun docs & planning ─────────────────────────────────
!speedrun/

# ── sett_ai assets & migration scripts ───────────────────────
!sett_ai/
sett_ai/db_products_current.json
sett_ai/product_summary.txt
sett_ai/product_summary_utf8.txt
sett_ai/mismatches.txt
sett_ai/mismatches_utf8.txt
sett_ai/inspect_products.php
sett_ai/check_compositions.php
sett_ai/analyze_current_data.php
sett_ai/verify_changes.php
sett_ai/clean_db.php


# ─────────────────────────────────────────────────────────────
# TIDAK di-push: wp-config.php, .env, uploads, core WP, dsb.
# ─────────────────────────────────────────────────────────────
